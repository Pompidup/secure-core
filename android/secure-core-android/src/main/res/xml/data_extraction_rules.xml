<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for Android 12+ (API 31+).
  Excludes all sensitive data from both cloud backup and device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="documents/" />
        <exclude domain="database" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="documents/" />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>

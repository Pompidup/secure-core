<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup rules for Android < 12 (Auto Backup).
  Excludes all sensitive data from Google cloud backup.
-->
<full-backup-content>
    <exclude domain="file" path="documents/" />
    <exclude domain="database" path="secure_core.db" />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
